# MongoDB Atlas connection string (leave empty for in-memory DB in local dev)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/maison-chronos?retryWrites=true&w=majority
# Example: mongodb+srv://zubair:YOUR_PASSWORD@finalcluster.9qoungu.mongodb.net/maison-chronos?retryWrites=true&w=majority
MONGODB_URI=

# JWT signing secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-me

# Admin seed route secret (POST /api/admin/seed with x-admin-secret header)
ADMIN_SECRET=your-admin-seed-secret

# Local Express port (optional)
PORT=5000
